# Port number to run the API server
PORT=5000

# Environment state
NODE_ENV=development

# MongoDB Connection String
MONGODB_URI=mongodb://localhost:27017/visitexpo

# JWT Secrets and Expire Configurations
JWT_SECRET=visitexpo_access_key_super_secret_change_me_in_production
JWT_REFRESH_SECRET=visitexpo_refresh_key_super_secret_change_me_in_production
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
